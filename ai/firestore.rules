rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────
    // Bootstrap admins encoded in rules so the very first sign-in works
    // before any `admins/{email}` doc exists. Keep in sync with
    // andjix-admin/config.js's BOOTSTRAP_ADMINS.
    function isBootstrapAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in [
          'emile.giovannie@gmail.com',
          'info.andjix@gmail.com'
        ];
    }

    function isAdmin() {
      return request.auth != null && (
        isBootstrapAdmin()
        || exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()))
      );
    }

    // ── Admins collection ──────────────────────────────────
    match /admins/{email} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Users (profiles + their messages) ──────────────────
    match /users/{uid} {
      // Owner reads/writes their own profile. Admins can read any profile.
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;

      match /messages/{messageId} {
        // Owner reads their own messages. Admins can read any.
        allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
        // All writes happen server-side via admin SDK.
        allow write: if false;
      }
    }

    // ── Leads (created server-side, read by admins) ────────
    match /leads/{leadId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Bookings (created server-side by Calendly webhook) ──
    match /bookings/{bookingId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Site config (Calendly URL, KB notes, etc.) ─────────
    match /config/{docId} {
      // Admin reads via dashboard + bot reads via admin SDK (bypasses rules).
      // No public read — kbNotes can be sensitive (rates, promos, internal notes).
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
